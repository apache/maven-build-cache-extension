<!--
    Base cache configuration for p19-cache-lifecycle.

    This project is designed to be used by multiple test classes. Each test that
    requires specific execution-control settings (runAlways, ignoreMissing, dirScan,
    effectivePomExcludes, logAllProperties, nolog) should patch this file in its
    isolated copy BEFORE running the build.

    Base behavior:
    - Cache enabled with XX hash algorithm.
    - skipTests tracked for maven-surefire-plugin:test with defaultValue="false".
      This lets TrackedPropertyDefaultValueTest, RunAlways*, and IgnoreMissing tests
      share the same base project.
-->
<cache xmlns="http://maven.apache.org/BUILD-CACHE-CONFIG/1.2.0"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://maven.apache.org/BUILD-CACHE-CONFIG/1.2.0
           https://maven.apache.org/xsd/build-cache-config-1.2.0.xsd">
    <configuration>
        <enabled>true</enabled>
        <hashAlgorithm>XX</hashAlgorithm>
    </configuration>
    <executionControl>
        <reconcile>
            <plugins>
                <plugin artifactId="maven-surefire-plugin" goal="test">
                    <reconciles>
                        <reconcile propertyName="skipTests" defaultValue="false"/>
                    </reconciles>
                </plugin>
            </plugins>
        </reconcile>
    </executionControl>
</cache>
