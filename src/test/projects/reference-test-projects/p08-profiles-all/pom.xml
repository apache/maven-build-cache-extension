<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
             http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>org.apache.maven.caching.test.p08</groupId>
    <artifactId>p08-profiles-all</artifactId>
    <version>1.0-SNAPSHOT</version>
    <packaging>jar</packaging>

    <name>P08 - Profiles All</name>
    <description>All profile activation types and all property sources.</description>

    <properties>
        <maven.compiler.source>1.8</maven.compiler.source>
        <maven.compiler.target>1.8</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <pom.prop>pom-value</pom.prop>
    </properties>

    <dependencies>
        <dependency>
            <groupId>junit</groupId>
            <artifactId>junit</artifactId>
            <version>4.13.2</version>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <pluginManagement>
            <plugins>
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-compiler-plugin</artifactId>
                    <version>@version.maven-compiler-plugin@</version>
                </plugin>
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-surefire-plugin</artifactId>
                    <version>@version.maven-surefire@</version>
                </plugin>
            </plugins>
        </pluginManagement>
    </build>

    <profiles>
        <!-- Profile 1: property activation -->
        <profile>
            <id>by-property</id>
            <activation>
                <property>
                    <name>env</name>
                    <value>ci</value>
                </property>
            </activation>
            <properties>
                <profile.by-property>active</profile.by-property>
                <build.env>ci</build.env>
            </properties>
            <!-- Add a dependency so profile activation changes the normalized model (cache key) -->
            <dependencies>
                <dependency>
                    <groupId>commons-lang</groupId>
                    <artifactId>commons-lang</artifactId>
                    <version>2.4</version>
                    <scope>test</scope>
                </dependency>
            </dependencies>
        </profile>

        <!-- Profile 2: OS activation -->
        <profile>
            <id>by-os</id>
            <activation>
                <os>
                    <family>unix</family>
                </os>
            </activation>
            <properties>
                <profile.by-os>active</profile.by-os>
            </properties>
        </profile>

        <!-- Profile 3: file activation -->
        <profile>
            <id>by-file</id>
            <activation>
                <file>
                    <exists>trigger.properties</exists>
                </file>
            </activation>
            <properties>
                <profile.by-file>active</profile.by-file>
            </properties>
        </profile>

        <!-- Profile 4: JDK activation (any JDK 11+) -->
        <profile>
            <id>by-jdk</id>
            <activation>
                <jdk>[11,)</jdk>
            </activation>
            <properties>
                <profile.by-jdk>active</profile.by-jdk>
            </properties>
        </profile>

        <!-- Profile 5: activeByDefault (resets when any other profile activates) -->
        <profile>
            <id>default-on</id>
            <activation>
                <activeByDefault>true</activeByDefault>
            </activation>
            <properties>
                <profile.default>active</profile.default>
                <build.env>default</build.env>
            </properties>
        </profile>
    </profiles>

</project>
