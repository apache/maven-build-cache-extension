<!--
    Minimal Checkstyle rule set used as a "source" file for the pom-packaged module.
    It lives at config/checkstyle-rules.xml and is declared as a cache input via the
    maven.build.cache.input.1 property in the parent pom.xml.

    Purpose: prove that modifying this file should cause a cache miss for the
    pom-packaged module (issue #423).
-->
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">
<module name="Checker">
    <module name="TreeWalker">
        <module name="WhitespaceAround"/>
    </module>
</module>
