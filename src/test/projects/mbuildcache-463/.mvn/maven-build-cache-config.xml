<!--
    Minimal cache configuration for the Issue 463 reproducer.

    Remote cache URL, server ID and local cache location are all supplied via
    system properties at test time (maven.build.cache.remote.url,
    maven.build.cache.remote.server.id, maven.build.cache.location) so that
    a single project tree can be shared between two simulated "build runners"
    that each use a separate local cache directory.

    The reconcile section is the key ingredient: it tells the extension that
    a cached surefire run with skipTests=true is acceptable when the *current*
    build also passes skipTests=true (skipValue), but represents an *incomplete*
    entry if the current build has skipTests=false.  That incompleteness is
    exactly what triggers the bug described in Issue 463.
-->
<cache xmlns="http://maven.apache.org/BUILD-CACHE-CONFIG/1.2.0"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://maven.apache.org/BUILD-CACHE-CONFIG/1.2.0
                           https://maven.apache.org/xsd/build-cache-config-1.2.0.xsd">

    <executionControl>
        <reconcile>
            <plugins>
                <plugin artifactId="maven-surefire-plugin" goal="test">
                    <reconciles>
                        <reconcile propertyName="skipTests" defaultValue="false" skipValue="true"/>
                    </reconciles>
                </plugin>
            </plugins>
        </reconcile>
    </executionControl>

</cache>
